// Canopy's JavaScript interop core.
//
// One opaque `Any` handle plus the zero-cost conversions and the
// property/method/global escape hatches every JS binding needs — so bindings
// describe *what* JS to call, not boilerplate `extern "js"` per operation.
//
// JS target only: a JS-FFI substrate has no meaning off the JavaScript backend.
import {
  "moonbitlang/async/js_async",
}

supported_targets = "js"
