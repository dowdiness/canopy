{
  "_doc": [
    "Declared FFI export manifest for the lambda app seam (S4 PR2, parallel-run).",
    "During parallel-run the hand-maintained files remain authoritative:",
    "ffi/lambda/moon.pkg (JS export array) and examples/ideal/main/crdt_reexport.mbt",
    "plus examples/ideal/main/moon.pkg. This manifest declares the expected seam;",
    "scripts/check-export-manifest.mjs reports symbol-level discrepancies.",
    "Not code-generated. Edit by hand alongside any export-surface change."
  ],
  "app": "lambda",
  "ffi_package": "ffi/lambda/moon.pkg",
  "app_package": "examples/ideal/main/moon.pkg",
  "wrapper_file": "examples/ideal/main/crdt_reexport.mbt",
